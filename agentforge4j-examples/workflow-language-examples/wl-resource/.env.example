# Environment configuration placeholder for this example.
#
# This example performs NO LLM call (its only step is a deterministic RESOURCE step), so these values are
# inert here. They are kept for surface consistency with the sibling workflow-language examples, where the
# same keys select the offline fake by default or a real provider once a key and provider module are set.

AGENTFORGE4J_EXAMPLE_LLM_PROVIDER=openai
AGENTFORGE4J_EXAMPLE_LLM_API_KEY=

