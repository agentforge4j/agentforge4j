# Environment configuration for running this example against a real LLM provider.
# Copy to your shell environment (or load with your tool of choice) and fill in a key.
# A provider module dependency must also be on this module's classpath — see pom.xml.
#
# Leaving AGENTFORGE4J_EXAMPLE_LLM_API_KEY unset keeps the example on the offline deterministic fake.

AGENTFORGE4J_EXAMPLE_LLM_PROVIDER=openai
AGENTFORGE4J_EXAMPLE_LLM_API_KEY=

# Optional explicit fake/real toggle (true/false). Unset = fake if and only if no API key is configured.
# AGENTFORGE4J_EXAMPLE_FAKE_LLM=true
