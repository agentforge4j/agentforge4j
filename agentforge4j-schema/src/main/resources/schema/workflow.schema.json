{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WorkflowDefinition",
  "type": "object",
  "required": ["kind", "id", "name", "steps"],
  "additionalProperties": false,
  "properties": {
    "kind": { "type": "string", "const": "WORKFLOW" },
    "id": {
      "type": "string",
      "description": "Unique workflow identifier. Must match the workflow directory name stem."
    },
    "name": {
      "type": "string",
      "description": "Human-readable workflow name."
    },
    "description": {
      "type": "string",
      "description": "Optional workflow description."
    },
    "uuid": {
      "type": "string",
      "format": "uuid",
      "description": "Optional stable workflow identity for server-side cost estimates (independent of directory id)."
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Executable" }
    },
    "requirements": {
      "type": "array",
      "items": { "$ref": "#/$defs/WorkflowRequirement" },
      "description": "Central, self-targeting requirement declarations. Opaque to the framework; interpreted by the configured RequirementResolver keyed on requirement type."
    },
    "ledgers": {
      "type": "array",
      "items": { "$ref": "#/$defs/LedgerDefinition" },
      "description": "Structured ledger declarations. Opaque to the framework core; schema refs resolve and merge rules apply at load and run time."
    }
  },
  "$defs": {
    "WorkflowRequirement": {
      "type": "object",
      "required": ["id", "type", "scope", "resolution"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "description": "Unique requirement id within the workflow." },
        "type": { "type": "string", "description": "Opaque requirement type; interpreted by the configured RequirementResolver. Not interpreted by the framework core." },
        "scope": { "type": "string", "enum": ["WORKFLOW", "STEP", "STEP_ACTION"] },
        "stepId": { "type": "string", "description": "Target step id when scope is STEP or STEP_ACTION." },
        "action": { "type": "string", "description": "Opaque target action when scope is STEP_ACTION." },
        "required": { "type": "boolean", "description": "Whether the workflow cannot run unless this requirement resolves." },
        "default": { "description": "Optional opaque default payload; carried as raw JSON and never interpreted by the framework." },
        "resolution": { "type": "string", "enum": ["INSTALL", "RUN_START", "INSTALL_OR_RUN_START", "DEFERRED"] }
      }
    },
    "Executable": {
      "oneOf": [
        { "$ref": "#/$defs/StepDefinition" },
        { "$ref": "#/$defs/BlueprintRef" },
        { "$ref": "#" }
      ]
    },
    "StepDefinition": {
      "type": "object",
      "required": ["kind", "stepId", "name", "behaviour"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "STEP" },
        "stepId": { "type": "string" },
        "name": { "type": "string" },
        "behaviour": { "$ref": "#/$defs/StepBehaviour" },
        "contextMapping": { "$ref": "#/$defs/ContextMapping" },
        "stepPrompt": {
          "type": "string",
          "description": "Optional prompt content for the step; may be blank depending on behaviour."
        },
        "maxUserPromptRounds": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum blocking USER_PROMPT pauses for this step before the run fails."
        },
        "modelTier": {
          "type": ["string", "null"],
          "enum": [
            "LITE",
            "STANDARD",
            "POWERFUL",
            "PREMIUM",
            null
          ],
          "description": "Optional capability tier overriding the agent tier for this step. A raw model pin always wins over the tier. Null inherits the agent tier."
        },
        "estimatedInputTokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional execution-estimation hint: expected input tokens consumed by this step. Advisory only; never affects runtime behaviour."
        },
        "estimatedOutputTokens": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional execution-estimation hint: expected output tokens generated by this step. Advisory only; never affects runtime behaviour."
        },
        "contextSelection": {
          "$ref": "#/$defs/ContextSelection",
          "description": "Optional declaration of the context this step receives (and may request). Absent keeps the current full-context behaviour."
        }
      }
    },
    "BlueprintRef": {
      "type": "object",
      "required": ["kind", "blueprintId"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "BLUEPRINT_REF" },
        "blueprintId": { "type": "string" }
      }
    },
    "StepBehaviour": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["AGENT", "SPAR", "WORKFLOW", "INPUT", "RESOURCE", "BRANCH", "FAIL", "RETRY_PREVIOUS", "VALIDATE", "ASSIGN_CONTEXT", "COMPACT"]
        }
      },
      "required": ["type"],
      "discriminator": {
        "propertyName": "type"
      },
      "oneOf": [
        { "$ref": "#/$defs/AgentBehaviour" },
        { "$ref": "#/$defs/SparBehaviour" },
        { "$ref": "#/$defs/WorkflowBehaviour" },
        { "$ref": "#/$defs/InputBehaviour" },
        { "$ref": "#/$defs/ResourceBehaviour" },
        { "$ref": "#/$defs/BranchBehaviour" },
        { "$ref": "#/$defs/FailBehaviour" },
        { "$ref": "#/$defs/RetryPreviousBehaviour" },
        { "$ref": "#/$defs/ValidateBehaviour" },
        { "$ref": "#/$defs/AssignContextBehaviour" },
        { "$ref": "#/$defs/CompactBehaviour" }
      ]
    },
    "AgentBehaviour": {
      "type": "object",
      "required": ["type", "agentRef", "transition"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "AGENT" },
        "agentRef": { "type": "string" },
        "transition": { "$ref": "#/$defs/StepTransition" },
        "retryPolicy": { "$ref": "#/$defs/RetryPolicy" }
      }
    },
    "SparBehaviour": {
      "type": "object",
      "required": ["type", "agentRef", "sparConfig", "transition"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "SPAR" },
        "agentRef": { "type": "string" },
        "sparConfig": { "$ref": "#/$defs/SparConfig" },
        "transition": { "$ref": "#/$defs/StepTransition" },
        "retryPolicy": { "$ref": "#/$defs/RetryPolicy" }
      }
    },
    "WorkflowBehaviour": {
      "type": "object",
      "required": ["type", "workflowRef", "transition"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "WORKFLOW" },
        "workflowRef": { "type": "string" },
        "transition": { "$ref": "#/$defs/StepTransition" }
      }
    },
    "InputBehaviour": {
      "type": "object",
      "required": ["type", "artifactId", "transition"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "INPUT" },
        "artifactId": { "type": "string" },
        "transition": { "$ref": "#/$defs/StepTransition" }
      }
    },
    "ResourceBehaviour": {
      "type": "object",
      "required": ["type", "resourcePath", "contextKey", "transition"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "const": "RESOURCE" },
        "resourcePath": {
          "type": "string",
          "description": "Resource path resolved by the runtime resource resolver under allowed roots."
        },
        "contextKey": {
          "type": "string",
          "description": "Context key under which the resource content is stored."
        },
        "transition": { "$ref": "#/$defs/StepTransition" }
      }
    },
    "BranchBehaviour": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "BRANCH" },
        "contextKey": { "type": "string", "minLength": 1 },
        "branches": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "null" },
              { "$ref": "#/$defs/Executable" }
            ]
          }
        },
        "predicates": {
          "type": "array",
          "items": { "$ref": "#/$defs/BranchPredicate" },
          "description": "Ordered predicates evaluated before the exact-match branches; first match wins."
        },
        "defaultBranch": { "$ref": "#/$defs/Executable" },
        "failOnUnmatched": {
          "type": "boolean",
          "description": "When true, an unmatched value with no defaultBranch fails the run instead of completing."
        }
      },
      "required": ["type", "contextKey"]
    },
    "BranchPredicate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "enum": ["MEMBER_OF", "EMPTY"] },
        "members": { "type": "array", "items": { "type": "string" } },
        "target": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/Executable" }
          ]
        }
      },
      "required": ["kind"]
    },
    "FailBehaviour": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "FAIL" },
        "reason": { "type": "string", "minLength": 1 }
      },
      "required": ["type", "reason"]
    },
    "RetryPreviousBehaviour": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "RETRY_PREVIOUS" },
        "retryStepId": { "type": "string", "minLength": 1 },
        "retryMode": { "enum": ["SINGLE_STEP", "FROM_STEP"] },
        "maxAttempts": { "type": "integer", "minimum": 1 },
        "fallback": { "$ref": "#/$defs/Executable" }
      },
      "required": ["type", "retryStepId", "retryMode", "maxAttempts", "fallback"]
    },
    "ValidateBehaviour": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "VALIDATE" },
        "validatorId": {
          "type": "string",
          "minLength": 1,
          "description": "Id of the ArtifactValidator applied to the captured artifacts."
        },
        "requiredArtifacts": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "description": "Allowlist of artifact paths that must be exactly present (no unexpected files)."
        },
        "contextEqualityContracts": {
          "type": "array",
          "items": { "$ref": "#/$defs/ContextEqualityContract" }
        }
      },
      "required": ["type", "validatorId", "requiredArtifacts"]
    },
    "ContextEqualityContract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "artifactPath": { "type": "string", "minLength": 1 },
        "jsonPointer": { "type": "string", "minLength": 1 },
        "contextKey": { "type": "string", "minLength": 1 }
      },
      "required": ["artifactPath", "jsonPointer", "contextKey"]
    },
    "AssignContextBehaviour": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "type": { "const": "ASSIGN_CONTEXT" },
        "contextKey": { "type": "string", "minLength": 1 },
        "value": { "$ref": "#/$defs/ScalarContextValue" }
      },
      "required": ["type", "contextKey", "value"]
    },
    "ScalarContextValue": {
      "type": "object",
      "required": ["type", "value"],
      "properties": {
        "type": { "type": "string", "enum": ["STRING", "NUMBER", "BOOLEAN"] },
        "value": {}
      }
    },
    "StepTransition": {
      "type": "string",
      "enum": ["AUTO", "HUMAN_REVIEW", "HUMAN_APPROVAL"]
    },
    "SparConfig": {
      "type": "object",
      "required": ["challengerAgentId", "maxRounds", "resolutionPrompt"],
      "additionalProperties": false,
      "properties": {
        "challengerAgentId": { "type": "string" },
        "maxRounds": { "type": "integer", "minimum": 1 },
        "resolutionPrompt": { "type": "string" }
      }
    },
    "RetryPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "allowRetry": { "type": "boolean" },
        "allowRetryFromPrevious": { "type": "boolean" },
        "allowAgentSwap": { "type": "boolean" },
        "allowPromptOverride": { "type": "boolean" },
        "maxAttempts": { "type": "integer", "minimum": 1 }
      }
    },
    "ContextMapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inputKeys": {
          "type": "array",
          "items": { "type": "string" }
        },
        "outputKeys": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "CompactBehaviour": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "source", "mode", "policy"],
      "properties": {
        "type": { "const": "COMPACT" },
        "source": { "$ref": "#/$defs/ContextSelector" },
        "mode": { "$ref": "#/$defs/CompactionMode" },
        "policy": { "$ref": "#/$defs/CompactionPolicy" }
      }
    },
    "CompactionMode": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string", "enum": ["DETERMINISTIC_EXTRACT", "LLM_SUMMARY"] }
      },
      "discriminator": { "propertyName": "type" },
      "oneOf": [
        { "$ref": "#/$defs/DeterministicExtract" },
        { "$ref": "#/$defs/LlmSummary" }
      ]
    },
    "DeterministicExtract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": { "const": "DETERMINISTIC_EXTRACT" }
      }
    },
    "LlmSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "modelTier"],
      "properties": {
        "type": { "const": "LLM_SUMMARY" },
        "modelTier": { "type": "string", "enum": ["LITE", "STANDARD", "POWERFUL", "PREMIUM"] }
      }
    },
    "CompactionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["minSourceUnits", "minDownstreamReuse"],
      "properties": {
        "minSourceUnits": { "type": "integer", "minimum": 0 },
        "minDownstreamReuse": { "type": "integer", "minimum": 0 }
      }
    },
    "ContextSelection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "selectors": {
          "type": "array",
          "items": { "$ref": "#/$defs/ContextSelector" }
        },
        "expandableScope": {
          "type": "array",
          "items": { "$ref": "#/$defs/ContextSelector" },
          "description": "Additional sources the step may request at run time. Empty means no expansion."
        },
        "maxExpansions": {
          "type": ["integer", "null"],
          "minimum": 1,
          "description": "Maximum RequestContextCommand rounds granted or denied within a single step invocation. Null defaults to 1; must be positive when present — declare an empty expandableScope to permit no expansion."
        }
      }
    },
    "ContextSelector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "ref"],
      "properties": {
        "kind": { "type": "string", "enum": ["LEDGER_SECTION", "ARTIFACT", "CONTEXT_PACK", "STATE_KEY", "STEP_OUTPUT"] },
        "ref": { "type": "string", "minLength": 1 },
        "variant": { "type": "string", "enum": ["FULL", "COMPACT_PREFERRED", "COMPACT_ONLY"] }
      }
    },
    "LedgerDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "schemaRef", "mergeStrategy"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "schemaRef": { "type": "string", "minLength": 1 },
        "mergeStrategy": { "type": "string", "enum": ["REPLACE_SECTION", "APPEND", "MERGE_BY_KEY"] },
        "mergeKeyField": { "type": ["string", "null"] }
      },
      "allOf": [
        {
          "if": { "properties": { "mergeStrategy": { "const": "MERGE_BY_KEY" } } },
          "then": { "required": ["mergeKeyField"], "properties": { "mergeKeyField": { "type": "string", "minLength": 1 } } },
          "else": { "properties": { "mergeKeyField": { "type": "null" } } }
        }
      ]
    }
  }
}
