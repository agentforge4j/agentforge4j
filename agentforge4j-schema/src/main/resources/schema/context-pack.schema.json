{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ContextPack",
  "type": "object",
  "required": ["name", "version", "variants"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Pack name; referenced by a ContextSelector of kind CONTEXT_PACK."
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Pack version. Packs are immutable per run."
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "variants": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": { "minLength": 1 },
      "additionalProperties": { "type": "string", "minLength": 1 },
      "description": "Map of variant name (e.g. full, compact) to the content file within the pack directory."
    }
  }
}
