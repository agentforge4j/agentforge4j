{
  "kind": "WORKFLOW",
  "id": "app-creator",
  "uuid": "a1c9e8f2-4b3d-4e5f-9a0b-1c2d3e4f5a02",
  "name": "Software Application Creator",
  "description": "Multi-agent workflow that takes an application idea and produces a complete delivery package: product vision, epics, architecture, implementation plan, and test plan. Uses PO, BA, Architect, Developer, and Tester agents in a structured SDLC sequence with human approval gates.",
  "steps": [
    {
      "kind": "STEP",
      "stepId": "collect-idea",
      "name": "Collect Application Idea",
      "behaviour": {
        "type": "INPUT",
        "artifactId": "app-idea",
        "transition": "AUTO"
      },
      "contextMapping": {
        "inputKeys": [],
        "outputKeys": ["appIdea"]
      }
    },
    {
      "kind": "BLUEPRINT_REF",
      "blueprintId": "po-refinement-loop"
    },
    {
      "kind": "STEP",
      "stepId": "po-finalise",
      "name": "Finalise Product Vision and Request Confirmation",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-creator-po-agent",
        "transition": "HUMAN_APPROVAL"
      },
      "stepPrompt": "po-finalise.step.prompt.md",
      "contextMapping": {
        "inputKeys": ["productVisionDraft"],
        "outputKeys": ["productVision"]
      }
    },
    {
      "kind": "STEP",
      "stepId": "ba-epics",
      "name": "BA Generates Epics and User Stories",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-creator-ba-agent",
        "transition": "HUMAN_APPROVAL"
      },
      "contextMapping": {
        "inputKeys": ["productVision"],
        "outputKeys": ["epics"]
      }
    },
    {
      "kind": "STEP",
      "stepId": "architect-design",
      "name": "Architect Designs System",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-creator-architect-agent",
        "transition": "AUTO"
      },
      "contextMapping": {
        "inputKeys": ["productVision", "epics"],
        "outputKeys": ["architectureDesign"]
      }
    },
    {
      "kind": "BLUEPRINT_REF",
      "blueprintId": "dev-architect-spar"
    },
    {
      "kind": "STEP",
      "stepId": "architect-confirm",
      "name": "Confirm Final Architecture",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-creator-architect-agent",
        "transition": "HUMAN_APPROVAL"
      },
      "stepPrompt": "architect-confirm.step.prompt.md",
      "contextMapping": {
        "inputKeys": ["architectureDesign"],
        "outputKeys": ["architectureDesign"]
      }
    },
    {
      "kind": "STEP",
      "stepId": "dev-plan",
      "name": "Developer Produces Implementation Plan",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-creator-developer-agent",
        "transition": "AUTO"
      },
      "contextMapping": {
        "inputKeys": ["productVision", "epics", "architectureDesign"],
        "outputKeys": ["implementationPlan"]
      }
    },
    {
      "kind": "STEP",
      "stepId": "tester-plan",
      "name": "Tester Produces Test Strategy and Cases",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-creator-tester-agent",
        "transition": "AUTO"
      },
      "contextMapping": {
        "inputKeys": ["productVision", "epics", "implementationPlan"],
        "outputKeys": ["testPlan", "testCases"]
      }
    },
    {
      "kind": "STEP",
      "stepId": "assemble-package",
      "name": "Assemble Final Delivery Package",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-creator-assembler-agent",
        "transition": "AUTO"
      },
      "stepPrompt": "assemble-package.step.prompt.md",
      "contextMapping": {
        "inputKeys": ["productVision", "epics", "architectureDesign", "implementationPlan", "testPlan", "testCases"],
        "outputKeys": []
      }
    }
  ]
}
