{
  "kind": "WORKFLOW",
  "id": "epic-implementation",
  "uuid": "a1c9e8f2-4b3d-4e5f-9a0b-1c2d3e4f5a05",
  "name": "Epic Implementation",
  "description": "Implements a single epic. Inputs (read from shared context): currentEpic, architectureDesign, generatedFiles. Outputs (written to shared context): generatedFiles, generatedTests, epicStatus (SUCCESS | NEEDS_REWORK | FAILED), epicNotes. Retries developer + tester up to 2 times if validator returns NEEDS_REWORK.",
  "steps": [
    {
      "kind": "STEP",
      "stepId": "understand-epic",
      "name": "Understand Epic Scope",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "epic-developer-agent",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["currentEpic", "architectureDesign", "generatedFiles"],
        "outputKeys": ["epicScope"]
      },
      "stepPrompt": "understand-epic"
    },
    {
      "kind": "STEP",
      "stepId": "implement-epic",
      "name": "Generate Implementation Files",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "epic-developer-agent",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": true,
          "allowAgentSwap": false,
          "allowPromptOverride": true,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["currentEpic", "architectureDesign", "epicScope", "generatedFiles", "epicNotes"],
        "outputKeys": ["generatedFiles"]
      },
      "stepPrompt": "implement-epic"
    },
    {
      "kind": "STEP",
      "stepId": "generate-tests",
      "name": "Generate Test Cases",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "epic-tester-agent",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["currentEpic", "epicScope", "generatedFiles", "generatedTests"],
        "outputKeys": ["generatedTests"]
      },
      "stepPrompt": "generate-tests"
    },
    {
      "kind": "STEP",
      "stepId": "validate-epic",
      "name": "Validate Epic Implementation",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "epic-validator-agent",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["currentEpic", "epicScope", "generatedFiles", "generatedTests", "architectureDesign"],
        "outputKeys": ["epicStatus", "epicNotes"]
      },
      "stepPrompt": "validate-epic"
    },
    {
      "kind": "STEP",
      "stepId": "rework-decision",
      "name": "Rework Decision",
      "behaviour": {
        "type": "BRANCH",
        "contextKey": "epicStatus",
        "branches": {
          "SUCCESS": null,
          "NEEDS_REWORK": {
            "kind": "STEP",
            "stepId": "rework-retry",
            "name": "Retry Implementation",
            "behaviour": {
              "type": "RETRY_PREVIOUS",
              "retryStepId": "implement-epic",
              "retryMode": "FROM_STEP",
              "maxAttempts": 2,
              "fallback": {
                "kind": "BLUEPRINT_REF",
                "blueprintId": "mark-epic-failed-blueprint"
              }
            },
            "contextMapping": {
              "inputKeys": [],
              "outputKeys": []
            }
          }
        },
        "defaultBranch": {
          "kind": "BLUEPRINT_REF",
          "blueprintId": "mark-epic-failed-blueprint"
        }
      },
      "contextMapping": {
        "inputKeys": ["epicStatus"],
        "outputKeys": []
      }
    }
  ]
}
