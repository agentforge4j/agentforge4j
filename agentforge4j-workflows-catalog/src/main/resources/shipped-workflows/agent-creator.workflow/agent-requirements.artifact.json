{
  "id": "agent-requirements",
  "items": [
    {
      "type": "TEXT",
      "id": "agent-name",
      "label": "Agent name",
      "required": true,
      "hint": "e.g. Code Reviewer, Legal Summariser"
    },
    {
      "type": "TEXT_AREA",
      "id": "agent-purpose",
      "label": "What should this agent do?",
      "required": true,
      "hint": "Describe the task, domain, and expected output in plain language."
    },
    {
      "type": "SINGLE_CHOICE",
      "id": "agent-locality",
      "label": "Where will this agent run?",
      "required": true,
      "options": ["CLOUD", "LOCAL"]
    },
    {
      "type": "SINGLE_CHOICE",
      "id": "preferred-provider",
      "label": "Preferred LLM provider",
      "required": true,
      "options": ["openai", "claude", "ollama", "vllm"]
    },
    {
      "type": "TEXT",
      "id": "preferred-model",
      "label": "Preferred model (leave blank for provider default)",
      "required": false
    },
    {
      "type": "TEXT_AREA",
      "id": "constraints",
      "label": "Constraints and boundaries (optional)",
      "required": false,
      "hint": "What must this agent never do? Any compliance or safety constraints?"
    }
  ]
}
