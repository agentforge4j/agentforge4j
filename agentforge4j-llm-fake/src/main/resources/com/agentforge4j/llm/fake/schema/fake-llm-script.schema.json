{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentforge4j.org/llm/fake/schema/fake-llm-script.schema.json",
  "title": "Fake LLM Script",
  "description": "Pre-scripted responses replayed by the agentforge4j-llm-fake provider, keyed by workflow/step/agent and call ordinal.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "responses"],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "responses": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["workflowId", "stepId", "agentId", "ordinal", "responseText"],
        "properties": {
          "workflowId": { "type": "string", "minLength": 1 },
          "stepId": { "type": "string", "minLength": 1 },
          "agentId": { "type": "string", "minLength": 1 },
          "ordinal": { "type": "integer", "minimum": 0 },
          "responseText": { "type": "string" },
          "tokenUsage": {
            "type": ["object", "null"],
            "additionalProperties": false,
            "properties": {
              "inputTokens": { "type": ["integer", "null"] },
              "outputTokens": { "type": ["integer", "null"] },
              "cachedInputTokens": { "type": ["integer", "null"] },
              "cacheWriteTokens": { "type": ["integer", "null"] }
            }
          }
        }
      }
    }
  }
}
