/scripts/emitter-output
/src/vocab
/docs/reference/config
/docs/reference/schemas
/docs/reference/providers
/docs/reference/behaviours.mdx
/docs/reference/commands.mdx
/docs/reference/events.mdx
/docs/reference/statuses.mdx

# Release-staging scratch area (materialised snapshot + swap backup; never committed).
/.release-staging

# Assembled GitHub Pages artifact (docs + javadoc), built at deploy time — never committed.
/_site

# Misc
.DS_Store
.env.local
.env.development.local
.env.test.local
.env.production.local

npm-debug.log*
yarn-debug.log*
yarn-error.log*
