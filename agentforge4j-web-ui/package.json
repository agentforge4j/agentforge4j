{
  "name": "agentforge4j-web-ui",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "npm run catalogue:build && vite",
    "dev:local": "npm run catalogue:build && cross-env AFB_LOCAL_BUILDER=1 vite --force",
    "catalogue:build": "node scripts/build-catalogue-data.mjs",
    "build": "npm run catalogue:build && tsc -b && vite build && node scripts/copy-404.mjs",
    "preview": "vite preview",
    "lint": "eslint src --max-warnings 0",
    "lint:content-gate": "node scripts/lint-content-gate.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:content-gate": "node --test scripts/lint-content-gate.test.mjs",
    "test:catalogue-data": "node --test scripts/build-catalogue-data.test.mjs",
    "check": "npm run catalogue:build && npm run lint && npm run lint:content-gate && npm run typecheck && npm run test && npm run test:content-gate && npm run test:catalogue-data && npm run build"
  },
  "dependencies": {
    "@agentforge4j/workflow-builder-react": "^0.3.0",
    "dagre": "^0.8.5",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^26.1.0",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.17.0",
    "ajv-formats": "^3.0.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.3",
    "vitest": "^4.1.8"
  }
}
