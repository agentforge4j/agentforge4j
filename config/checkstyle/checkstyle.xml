<?xml version="1.0"?>
<!DOCTYPE module PUBLIC
    "-//Checkstyle//DTD Checkstyle Configuration 1.3//EN"
    "https://checkstyle.org/dtds/configuration_1_3.dtd">

<!--
  Minimal AgentForge4j Checkstyle ruleset.

  Deliberately small: it enforces a handful of high-signal, zero-reformat rules that mirror the
  project conventions ("braces on all control flow", no unused/redundant imports, no empty blocks).
  It is NOT a full style profile - SpotBugs and human review cover the rest. Keeping the rule set
  tight avoids mass reformatting and false positives on the existing main sources.

  The "no var in production" convention is intentionally NOT enforced here: a RegexpSinglelineJava
  rule for \bvar\b would also flag the literal word "var" inside comments, Javadoc, and string
  literals (false positives), so it was omitted per the design's "omit if risk exists" guidance.
-->
<module name="Checker">
  <property name="severity" value="error"/>
  <property name="charset" value="UTF-8"/>
  <property name="fileExtensions" value="java"/>

  <module name="TreeWalker">
    <!-- Braces on all control-flow statements (if/else/for/while/do). -->
    <module name="NeedBraces"/>

    <!-- No unused imports. -->
    <module name="UnusedImports">
      <property name="processJavadoc" value="true"/>
    </module>

    <!-- No duplicate or java.lang/same-package imports. -->
    <module name="RedundantImport"/>

    <!-- No SILENT empty code blocks. option=text treats a block as non-empty when it contains a
         comment, so intentional, documented no-op branches (e.g. an exhaustive instanceof else-if
         with an explanatory comment) pass, while truly silent empty blocks still fail. -->
    <module name="EmptyBlock">
      <property name="option" value="text"/>
      <property name="tokens"
                value="LITERAL_DO,LITERAL_ELSE,LITERAL_FINALLY,LITERAL_IF,LITERAL_FOR,
                       LITERAL_TRY,LITERAL_WHILE,INSTANCE_INIT,STATIC_INIT"/>
    </module>
  </module>
</module>
