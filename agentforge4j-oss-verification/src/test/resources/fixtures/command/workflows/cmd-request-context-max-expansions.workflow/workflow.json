        "value": { "type": "STRING", "value": "a" }
      }
    },
    {
      "kind": "STEP",
      "stepId": "seed-b",
      "name": "Seed B",
      "behaviour": {
        "type": "ASSIGN_CONTEXT",
        "contextKey": "note-b",
        "value": { "type": "STRING", "value": "b" }
      }
    },
    {
      "kind": "STEP",
      "stepId": "run",
      "name": "Run Agent",
      "behaviour": { "type": "AGENT", "agentRef": "context-agent", "transition": "AUTO" },
      "contextSelection": {
        "selectors": [],
