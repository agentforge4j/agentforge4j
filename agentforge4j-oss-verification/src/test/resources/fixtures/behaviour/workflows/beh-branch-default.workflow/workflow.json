{
  "kind": "WORKFLOW",
  "schemaVersion": 1,
  "id": "beh-branch-default",
  "name": "Branch Default",
  "steps": [
    {
      "kind": "STEP",
      "stepId": "decide",
      "name": "Decide",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "branch-agent",
        "transition": "AUTO"
      }
    },
    {
      "kind": "STEP",
      "stepId": "route",
      "name": "Route",
      "behaviour": {
        "type": "BRANCH",
        "contextKey": "decision",
        "branches": {
          "go": {
            "kind": "STEP",
            "stepId": "go-fail",
            "name": "Go Fail",
            "behaviour": {
              "type": "FAIL",
              "reason": "routed to go"
            }
          }
        }
      }
    }
  ]
}
