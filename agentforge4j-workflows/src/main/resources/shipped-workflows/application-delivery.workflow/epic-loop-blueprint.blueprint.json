{
  "kind": "BLUEPRINT",
  "blueprintId": "epic-loop-blueprint",
  "name": "Per-Epic Implementation Loop",
  "behaviour": {
    "loopConfig": {
      "terminationStrategy": "FOR_EACH",
      "forEachContextKey": "epics",
      "maxIterations": 50,
      "maxIterationsAction": "FAIL"
    },
    "transition": "AUTO"
  },
  "steps": [
    {
      "kind": "STEP",
      "stepId": "invoke-epic-implementation",
      "name": "Implement Current Epic",
      "behaviour": {
        "type": "WORKFLOW",
        "workflowRef": "epic-implementation",
        "transition": "AUTO"
      },
      "contextMapping": {
        "inputKeys": ["currentEpic", "architectureDesign", "generatedFiles", "generatedTests"],
        "outputKeys": ["generatedFiles", "generatedTests", "epicStatus", "epicNotes"]
      }
    }
  ]
}
