{
  "kind": "WORKFLOW",
  "id": "application-delivery",
  "uuid": "a1c9e8f2-4b3d-4e5f-9a0b-1c2d3e4f5a07",
  "name": "Application Delivery",
  "description": "End-to-end AI-driven software delivery pipeline. Collects an application idea, refines requirements via dynamic PO questioning, generates epics, designs architecture, then iterates over each epic invoking the epic-implementation sub-workflow. Assembles a final delivery package with executive summary.",
  "steps": [
    {
      "kind": "STEP",
      "stepId": "collect-app-idea",
      "name": "Collect Application Idea",
      "behaviour": {
        "type": "INPUT",
        "artifactId": "app-idea",
        "transition": "AUTO"
      },
      "contextMapping": {
        "inputKeys": [],
        "outputKeys": [
          "appIdea"
        ]
      }
    },
    {
      "kind": "BLUEPRINT_REF",
      "blueprintId": "po-refinement-loop"
    },
    {
      "kind": "STEP",
      "stepId": "approve-product-vision",
      "name": "Approve Product Vision",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-delivery-po-agent",
        "transition": "HUMAN_APPROVAL",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 1
        }
      },
      "contextMapping": {
        "inputKeys": [
          "productVision"
        ],
        "outputKeys": []
      },
      "stepPrompt": "approve-product-vision"
    },
    {
      "kind": "STEP",
      "stepId": "generate-epics",
      "name": "Generate Epics and User Stories",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-delivery-ba-agent",
        "transition": "HUMAN_APPROVAL",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": true,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": [
          "productVision"
        ],
        "outputKeys": [
          "epics"
        ]
      },
      "stepPrompt": "generate-epics"
    },
    {
      "kind": "STEP",
      "stepId": "design-architecture",
      "name": "Design System Architecture",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-delivery-architect-agent",
        "transition": "HUMAN_APPROVAL",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": true,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": [
          "productVision",
          "epics"
        ],
        "outputKeys": [
          "architectureDesign"
        ]
      },
      "stepPrompt": "design-architecture"
    },
    {
      "kind": "BLUEPRINT_REF",
      "blueprintId": "epic-loop-blueprint"
    },
    {
      "kind": "STEP",
      "stepId": "assemble-delivery",
      "name": "Assemble Delivery Package",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-delivery-assembler-agent",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": [
          "productVision",
          "epics",
          "architectureDesign",
          "generatedFiles",
          "generatedTests"
        ],
        "outputKeys": [
          "deliveryPackage"
        ]
      },
      "stepPrompt": "assemble-delivery"
    },
    {
      "kind": "STEP",
      "stepId": "executive-summary",
      "name": "Generate Executive Summary",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "app-delivery-summary-agent",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": [
          "productVision",
          "epics",
          "architectureDesign",
          "deliveryPackage"
        ],
        "outputKeys": [
          "executiveSummary"
        ]
      },
      "stepPrompt": "executive-summary"
    }
  ]
}
