{
  "kind": "WORKFLOW",
  "id": "application-delivery",
  "uuid": "a1c9e8f2-4b3d-4e5f-9a0b-1c2d3e4f5a07",
  "name": "Application Delivery",
  "description": "End-to-end AI-driven software delivery pipeline. Collects an application idea, refines requirements via dynamic PO questioning, generates epics, designs architecture, then iterates over each epic invoking the epic-implementation sub-workflow. Assembles a final delivery package with executive summary.",
  "author": "AgentForge4J",
  "contact": "https://github.com/agentforge4j",
  "version": "1.0.0",
  "artifacts": {
    "app-idea": {
      "id": "app-idea",
      "items": [
        {
          "type": "TEXT_AREA",
          "id": "appIdea",
          "label": "What application do you want to build?",
          "required": true
        }
      ]
    }
  },
  "blueprints": {
    "po-refinement-loop": {
      "kind": "BLUEPRINT",
      "blueprintId": "po-refinement-loop",
      "name": "PO Refinement Loop",
      "behaviour": {
        "loopConfig": {
          "terminationStrategy": "AGENT_SIGNAL",
          "maxIterations": 8,
          "maxIterationsAction": "AWAIT_USER"
        },
        "transition": "AUTO"
      },
      "steps": [
        {
          "kind": "STEP",
          "stepId": "po-refinement",
          "name": "PO Requirements Refinement",
          "behaviour": {
            "type": "AGENT",
            "agentRef": "application-delivery.po",
            "transition": "AUTO",
            "retryPolicy": {
              "allowRetry": true,
              "allowRetryFromPrevious": false,
              "allowAgentSwap": false,
              "allowPromptOverride": true,
              "maxAttempts": 3
            }
          },
          "contextMapping": {
            "inputKeys": ["appIdea", "productVision"],
            "outputKeys": ["productVision"]
          },
          "stepPrompt": "po-refinement"
        }
      ]
    },
    "epic-loop-blueprint": {
      "kind": "BLUEPRINT",
      "blueprintId": "epic-loop-blueprint",
      "name": "Per-Epic Implementation Loop",
      "behaviour": {
        "loopConfig": {
          "terminationStrategy": "FOR_EACH",
          "forEachContextKey": "epics",
          "maxIterations": 50,
          "maxIterationsAction": "FAIL"
        },
        "transition": "AUTO"
      },
      "steps": [
        {
          "kind": "STEP",
          "stepId": "invoke-epic-implementation",
          "name": "Implement Current Epic",
          "behaviour": {
            "type": "WORKFLOW",
            "workflowRef": "epic-implementation",
            "transition": "AUTO"
          },
          "contextMapping": {
            "inputKeys": ["currentEpic", "architectureDesign", "generatedFiles", "generatedTests"],
            "outputKeys": ["generatedFiles", "generatedTests", "epicStatus", "epicNotes"]
          }
        }
      ]
    }
  },
  "steps": [
    {
      "kind": "STEP",
      "stepId": "collect-app-idea",
      "name": "Collect Application Idea",
      "behaviour": {
        "type": "INPUT",
        "artifactId": "app-idea",
        "transition": "AUTO"
      },
      "contextMapping": {
        "inputKeys": [],
        "outputKeys": ["appIdea"]
      }
    },
    {
      "kind": "BLUEPRINT_REF",
      "blueprintId": "po-refinement-loop"
    },
    {
      "kind": "STEP",
      "stepId": "approve-product-vision",
      "name": "Approve Product Vision",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "application-delivery.po",
        "transition": "HUMAN_APPROVAL",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 1
        }
      },
      "contextMapping": {
        "inputKeys": ["productVision"],
        "outputKeys": []
      },
      "stepPrompt": "approve-product-vision"
    },
    {
      "kind": "STEP",
      "stepId": "generate-epics",
      "name": "Generate Epics and User Stories",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "application-delivery.ba",
        "transition": "HUMAN_APPROVAL",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": true,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["productVision"],
        "outputKeys": ["epics"]
      },
      "stepPrompt": "generate-epics"
    },
    {
      "kind": "STEP",
      "stepId": "design-architecture",
      "name": "Design System Architecture",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "application-delivery.architect",
        "transition": "HUMAN_APPROVAL",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": true,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["productVision", "epics"],
        "outputKeys": ["architectureDesign"]
      },
      "stepPrompt": "design-architecture"
    },
    {
      "kind": "BLUEPRINT_REF",
      "blueprintId": "epic-loop-blueprint"
    },
    {
      "kind": "STEP",
      "stepId": "assemble-delivery",
      "name": "Assemble Delivery Package",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "application-delivery.assembler",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["productVision", "epics", "architectureDesign", "generatedFiles", "generatedTests"],
        "outputKeys": ["deliveryPackage"]
      },
      "stepPrompt": "assemble-delivery"
    },
    {
      "kind": "STEP",
      "stepId": "executive-summary",
      "name": "Generate Executive Summary",
      "behaviour": {
        "type": "AGENT",
        "agentRef": "application-delivery.summary",
        "transition": "AUTO",
        "retryPolicy": {
          "allowRetry": true,
          "allowRetryFromPrevious": false,
          "allowAgentSwap": false,
          "allowPromptOverride": false,
          "maxAttempts": 2
        }
      },
      "contextMapping": {
        "inputKeys": ["productVision", "epics", "architectureDesign", "deliveryPackage"],
        "outputKeys": ["executiveSummary"]
      },
      "stepPrompt": "executive-summary"
    }
  ]
}
